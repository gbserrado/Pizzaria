// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string
//   - createdAt: timestamp
//
// Collection: orders
// Document ID: {orderId}
// Fields:
//   - userId: string (required)
//   - items: list (required)
//   - total: number (required)
//   - status: string (required, ['pending', 'preparing', 'delivering', 'completed', 'cancelled'])
//   - address: map
//   - paymentMethod: string
//   - createdAt: timestamp (required)
//   - couponCode: string
//   - discount: number
//
// Collection: coupons
// Document ID: {couponId}
// Fields:
//   - code: string (required)
//   - discountPercent: number (required)
//   - active: bool (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global deny by default
    match /{document=**} { allow read, write: if false; }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.matches("(?i)Gabriel06nf@gmail.com") ||
         request.auth.token.email.matches("(?i)admin@ouropreto.com"));
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow update: if isAuthenticated() && request.auth.uid == userId && incoming().uid == existing().uid && incoming().email == existing().email;
      allow create: if isAuthenticated() && request.auth.uid == userId && incoming().uid == request.auth.uid;
    }

    match /orders/{orderId} {
      allow get: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      
      // Strict creation validation: Prevents missing keys, fake totals, spoofed user IDs
      allow create: if isAuthenticated() &&
        incoming().keys().hasAll(['userId', 'items', 'total', 'status']) &&
        incoming().userId == request.auth.uid &&
        incoming().items is list &&
        incoming().items.size() <= 50 &&
        incoming().total is number &&
        incoming().total >= 0 &&
        incoming().status == 'received'; // Initial state strictly protected
        
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /config/{configId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /menu/{pizzaId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /loyalty/{phone} {
      allow read: if true; 
      allow write: if isAdmin();
    }
  }
}
